# FLIPPY Worker environment variables
# Copy this to .env and fill in real values.

# ── Required ─────────────────────────────────────────────────────────────────

# Railway Postgres connection string (same one used by the backend)
DATABASE_URL=postgresql://postgres:<password>@<host>:<port>/railway

# Google Gemini API key (same key as backend)
GEMINI_API_KEY=

GOOGLE_API_KEY=

# Required by backend/mysite/settings.py even though the worker doesn't use OpenAI
OPENAI_API_KEY=

# Django secret key (must match the backend's SECRET_KEY)
SECRET_KEY=

# ── Scanner behaviour ─────────────────────────────────────────────────────────

# Must be True — this is what allows Playwright to run on this machine
ENABLE_SCANNER=True

# Set False so the worker uses Railway Postgres (not local SQLite)
USE_LOCAL_DB=False

# ── Django settings ───────────────────────────────────────────────────────────

DEBUG=False
DOMAIN=http://localhost/
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost/
CORS_ALLOWED_ORIGINS=http://localhost/
TZ=America/New_York
ADMIN_URL=admin

# ── Optional: notifications ───────────────────────────────────────────────────

SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
SENDGRID_TO_EMAIL=
